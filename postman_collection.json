{
  "info": {
    "name": "WebAPI - Postman Collection",
    "_postman_id": "webapi-collection-001",
    "description": "Collection for WebAPI endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://web-api-indol.vercel.app",
      "type": "string"
    },
    { "key": "provinceId", "value": "1" },
    { "key": "districtId", "value": "1" },
    { "key": "stationId", "value": "1" },
    { "key": "vehicleId", "value": "1" },
    { "key": "modelId", "value": "1" }
  ],
  "item": [
