      "name": "Root",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": ["/"]
        }
      }
    },
    {
      "name": "List Provinces",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/provinces", "host": ["{{base_url}}"], "path": ["provinces"] }
      }
    },
    {
      "name": "Get Province by ID",
      "request": {
        "method": "GET",
        "header": [],
